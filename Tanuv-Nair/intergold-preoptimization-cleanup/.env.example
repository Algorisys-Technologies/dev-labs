# Optional: set to true, 1, yes, or on to enable file logging.
# Default behavior (when unset): logging disabled
ENABLE_LOGGING="false"

# Name of the appended remarks column in the output CSV.
# Default: Remarks
REMARKS_COLUMN_NAME="Remarks"

# Column index (0-based) for ProdEndDt in the input CSV (dd-mm-yyyy).
# You can also provide Excel-style column letters (e.g. A, Z, AA).
PROD_END_DT_COL_INDEX="W"

# Column index for Bloc in the input CSV.
BLOC_COL_INDEX="BD"

# Column index for the first process completion date column to scan (inclusive).
# Point this at the ZCAD column in your sheet (header name must match the process map).
# Same format as other *_COL_INDEX vars: 0-based number or Excel letters (A, Z, AA).
FIRST_BLOC_PROCESS_COL_INDEX="AB"

# Column index for the last process completion date column to scan (inclusive).
# Point this at the Polish column in your sheet (header name must match the process map).
LAST_BLOC_PROCESS_COL_INDEX="AY"

# Year window X used to treat dates as null/invalid when their year is outside
# [CurrentYear-X, CurrentYear+X].
NULL_DATE_YEAR_WINDOW_X="5"

# Text written into the remarks column when an extension is needed.
# Default behavior (when unset): "extension needed"
REMARKS_EXTENSION_NEEDED="extension needed"

# Process map and holiday CSV file paths are NOT configured here.
# Use -process-map / -holiday-master, or place preoptimization_process_map.csv and holiday_master.csv
# next to the executable (defaults).

# Column indices in the process-map CSV (after the header row): key = process code, value = mapped column name(s).
# Same rules as other *_COL_INDEX vars: 0-based number or Excel letters (A, B, ..., AA).
# Defaults when unset: A (0) and B (1).
PROCESS_MAP_KEY_COL_INDEX="A"
PROCESS_MAP_VALUE_COL_INDEX="B"

# Holiday CSV: 0-based column indices (numeric or Excel letters). Defaults when unset: A (date) and B (label).
# Key column = holiday date; value column = non-empty label per row. They must differ.
HOLIDAYS_KEY_COL_INDEX="A"
HOLIDAYS_VALUE_COL_INDEX="B"

