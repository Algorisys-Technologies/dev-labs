<!DOCTYPE html>
<html>
<head>
  <title><%= assigns[:title] || "Ignite LiveView" %></title>
  <style>
    body {
      font-family: system-ui, -apple-system, sans-serif;
      text-align: center;
      margin-top: 50px;
      color: #333;
    }
    button { cursor: pointer; margin: 5px; }
    #ignite-app { min-height: 100px; }
    .status { font-size: 12px; color: #888; min-height: 18px; margin: 10px 0; }
    .status.connected { color: #27ae60; }
    .status.disconnected { color: #e74c3c; }
  </style>
</head>
<body>
  <p class="status" id="ignite-status"></p>
  <div id="ignite-app" data-live-path="<%= assigns[:live_path] || "/live" %>" data-live-routes='<%= assigns[:live_routes] || "{}" %>'>Connecting...</div>
  <hr>
  <p><small>Powered by <a href="/">Ignite</a></small></p>
  <script src="<%= Ignite.Controller.static_path("morphdom.min.js") %>"></script>
  <script src="<%= Ignite.Controller.static_path("hooks.js") %>"></script>
  <script src="<%= Ignite.Controller.static_path("ignite.js") %>"></script>
</body>
</html>
