<!DOCTYPE html>
<html>
<head>
    <title>Ignite Web Framework - Profile</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: #fdfdfd;
            color: #333;
            max-width: 600px;
            margin: 50px auto;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        h1 { color: #f4611e; }
        .info { background: #fff; padding: 15px; border-left: 4px solid #f4611e; }
        footer { margin-top: 30px; font-size: 0.8em; color: #777; border-top: 1px solid #eee; padding-top: 10px; }
    </style>
</head>
<body>
    <h1>User Profile</h1>
    <div class="info">
        <p><strong>Name:</strong> <%= assigns[:name] %></p>
        <p><strong>ID:</strong> <%= assigns[:id] %></p>
        <p><strong>Email:</strong> <%= assigns[:email] %></p>
    </div>
    <footer>
        <p>Generated by Ignite Framework on <%= DateTime.utc_now() %></p>
    </footer>
</body>
</html>
